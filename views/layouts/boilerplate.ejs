<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        WanderLust - <%= typeof listing !=="undefined" ? listing.title : "" %>
    </title>
    <link rel="icon" href="/favicon.png" type="image/png">
   <!-- Bootstrap 5 -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/new.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-light fixed-top navbar-custom" id="mainNavbar">
  <div class="container-fluid">

    <!-- Logo -->
    <a class="navbar-brand logo" href="#">
      <i class="bi bi-airplane-fill"></i> WanderLust
    </a>

    <!-- Mobile Toggle -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse justify-content-between" id="navbarContent">

      <!-- Center Search -->
      <form class="d-flex mx-auto search-wrapper align-items-center">
        <input class="form-control border-0 shadow-none search-box"
          type="search"
          placeholder="Where to? | Any week | Add guests">
        <button class="search-btn d-flex justify-content-center align-items-center ms-2">
          <i class="bi bi-search"></i>
        </button>
      </form>

      <!-- Right Side -->
      <ul class="navbar-nav align-items-center">

        <li class="nav-item me-3">
          <a class="nav-link" href="#">Become a Host</a>
        </li>

        <li class="nav-item me-3">
          <a class="nav-link" href="#">
            <i class="bi bi-globe fs-5"></i>
          </a>
        </li>

        <li class="nav-item dropdown">
          <a class="nav-link profile-menu d-flex align-items-center"
             href="#" role="button" data-bs-toggle="dropdown">
            <i class="bi bi-list me-2"></i>
            <i class="bi bi-person-circle fs-5"></i>
          </a>

          <ul class="dropdown-menu dropdown-menu-end shadow">
            <li><a class="dropdown-item" href="#">Sign up</a></li>
            <li><a class="dropdown-item" href="#">Log in</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#">Host your home</a></li>
            <li><a class="dropdown-item" href="#">Help Center</a></li>
          </ul>
        </li>

      </ul>

    </div>
  </div>
</nav>
    <!-- ***************************************************************** -->
    <div class="container">
        <%- body %>
    </div>
</body>
<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
window.addEventListener("scroll", function() {
  const navbar = document.getElementById("mainNavbar");
  navbar.classList.toggle("scrolled", window.scrollY > 50);
});
</script>
</html>